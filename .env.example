# ──────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` (which is gitignored) and fill in your real values:
#     cp .env.example .env
# `scripts/config.py` loads these into the process environment at app startup.
# Leave a line blank to use the built-in default / treat as "not configured".
# NEVER commit your real .env.
# ──────────────────────────────────────────────────────────────────────────

# ── LLM for PDF field extraction (Phase 2: 上传巨潮 PDF 自动识别) ──────────────
# Any OpenAI-compatible provider works (DeepSeek / Qwen / Kimi / Zhipu / OpenAI).
# Required for the PDF auto-extract feature; without it the app falls back to
# manual input.
LLM_API_KEY=

# Optional: provider base URL. Leave BLANK for OpenAI. Examples:
#   DeepSeek : https://api.deepseek.com
#   Moonshot : https://api.moonshot.cn/v1
#   Zhipu    : https://open.bigmodel.cn/api/paas/v4
LLM_BASE_URL=

# Optional: model name. Blank → default 'gpt-4o-mini'. Examples:
#   deepseek-chat / moonshot-v1-8k / glm-4 / qwen-plus
LLM_MODEL=

# ── Tushare token for market-data refresh (future phase: market_source) ────
# Free token at https://tushare.pro . Not needed yet for Phase 1/2.
TUSHARE_TOKEN=
